# Copy this file to .env and fill in real values. .env is gitignored.

# --- Database (used by docker-compose.yml and config/settings.py) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=job_market
DB_USER=postgres
DB_PASSWORD=postgres

# --- Collector: shared HTTP behavior (optional - defaults are sane) ---
# API_TIMEOUT_SECONDS=20
# API_RETRY_ATTEMPTS=3
# API_RETRY_DELAY_SECONDS=3

# --- Collector: no-key sources (optional overrides) ---
# REMOTEOK_API_URL=https://remoteok.com/api
# ARBEITNOW_API_URL=https://arbeitnow.com/api/job-board-api

# --- Collector: Adzuna (https://developer.adzuna.com/) ---
# Inactive until both of these are set - collector/sources/registry.py
# only activates a source once its required settings are all present.
# ADZUNA_APP_ID=
# ADZUNA_APP_KEY=
# ADZUNA_COUNTRY=us

# --- Collector: USAJobs (https://developer.usajobs.gov/) ---
# Requires an API key AND your email as the User-Agent header (their API
# terms, not optional). Inactive until both are set.
# USAJOBS_API_KEY=
# USAJOBS_EMAIL=

# --- Snowflake (optional - only used if these are set) ---
# SNOWFLAKE_ACCOUNT=
# SNOWFLAKE_USER=
# SNOWFLAKE_PASSWORD=
# SNOWFLAKE_WAREHOUSE=JMI_WH
# SNOWFLAKE_DATABASE=JMI_DB
# SNOWFLAKE_SCHEMA=CURATED
# SNOWFLAKE_ROLE=

# --- AI module (ai/) ---
# Which provider answers chat requests, and which one generates
# embeddings for the RAG chatbot - independent settings because Anthropic
# has no embeddings API. Default is "openai" for both.
# AI_CHAT_PROVIDER=openai
# AI_EMBEDDING_PROVIDER=openai

# OpenAI (https://platform.openai.com/api-keys) - default provider.
OPENAI_API_KEY=
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic/Claude (https://console.anthropic.com/) - chat only, set
# AI_CHAT_PROVIDER=claude to use it. Still needs an embedding provider.
# ANTHROPIC_API_KEY=
# ANTHROPIC_CHAT_MODEL=claude-3-5-sonnet-20241022

# Azure OpenAI - set AI_CHAT_PROVIDER/AI_EMBEDDING_PROVIDER=azure_openai.
# Deployment names, not model names (whatever you named them in Azure AI Studio).
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_CHAT_DEPLOYMENT=
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
# AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Ollama (https://ollama.com) - free, local, no key. Must be installed,
# running, and have OLLAMA_CHAT_MODEL pulled first. Set
# AI_CHAT_PROVIDER/AI_EMBEDDING_PROVIDER=ollama to use it.
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_CHAT_MODEL=llama3.1

# RAG vector store: "memory" (default) needs no account - persists to
# data/ai/memory_vector_store.json. Set VECTOR_STORE_PROVIDER=pinecone
# once PINECONE_API_KEY is set (free tier at https://www.pinecone.io/).
# VECTOR_STORE_PROVIDER=memory
# PINECONE_API_KEY=
# PINECONE_INDEX_NAME=jobpulse-jobs

# AI_RATE_LIMIT_PER_MINUTE=20
# AI_MAX_MESSAGE_LENGTH=2000

# --- Auth (auth/) ---
# Base URL of the frontend - used to build links that go into emails
# (password reset) and as the default OAuth redirect target below.
# FRONTEND_URL=http://localhost:5173

# JWT signing key. If unset, a random per-process secret is generated so
# local dev still works, but every restart invalidates existing tokens -
# set a fixed value for anything beyond local dev.
# JWT_SECRET_KEY=
# JWT_ALGORITHM=HS256
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
# JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
# How long a refresh token lives when "Remember me" is left unchecked at login.
# JWT_REMEMBER_ME_OFF_REFRESH_DAYS=1

# Google OAuth (https://console.cloud.google.com/apis/credentials) -
# inactive (buttons return a clear 503, not a crash) until both are set.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# GitHub OAuth (https://github.com/settings/developers) - same
# inactive-until-configured behavior as Google above.
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/github/callback

# Where the frontend lands after an OAuth redirect completes.
# OAUTH_FRONTEND_REDIRECT_URL=http://localhost:5173/oauth/callback

# How long a forgot-password reset link stays valid.
# PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# RESUME_UPLOAD_DIR=data/resumes
# RESUME_MAX_SIZE_MB=5

# API_RATE_LIMIT_PER_MINUTE=60
# AUTH_RATE_LIMIT_PER_MINUTE=10

# --- Caching / background jobs (utils/cache.py, jobs/) ---
# Unset by default - falls back to an in-memory cache and a directly
# callable alert-checking function (no broker needed) respectively.
# REDIS_URL=redis://localhost:6379/0
# CACHE_DEFAULT_TTL_SECONDS=60

# --- Email (utils/email.py) ---
# Unset by default - notifications are logged (app log + notification_log
# table) instead of actually sent.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM_ADDRESS=noreply@jobpulse.local

# --- Logging (optional) ---
# LOG_LEVEL=INFO
