# Copy this file to .env and fill in real values. .env is gitignored.

# --- Database (used by docker-compose.yml and config/settings.py) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=job_market
DB_USER=postgres
DB_PASSWORD=postgres

# --- Collector (optional - defaults are sane) ---
# API_URL=https://remoteok.com/api
# API_TIMEOUT_SECONDS=20
# API_RETRY_ATTEMPTS=3
# API_RETRY_DELAY_SECONDS=3

# --- Logging (optional) ---
# LOG_LEVEL=INFO
