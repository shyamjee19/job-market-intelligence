name: job-market-intelligence

services:
  # ---------------------------------------------------------------------
  # Kafka (KRaft mode - no Zookeeper needed)
  # ---------------------------------------------------------------------
  kafka:
    image: bitnami/kafka:3.7
    container_name: jmi-kafka
    ports:
      - "9092:9092"     # client access from host (collector, spark)
    environment:
      KAFKA_CFG_NODE_ID: "0"
      KAFKA_CFG_PROCESS_ROLES: controller,broker
      KAFKA_CFG_CONTROLLER_QUORUM_VOTERS: 0@kafka:9093
      KAFKA_CFG_LISTENERS: PLAINTEXT://:9092,CONTROLLER://:9093,EXTERNAL://:29092
      KAFKA_CFG_ADVERTISED_LISTENERS: PLAINTEXT://kafka:9092,EXTERNAL://localhost:9092
      KAFKA_CFG_LISTENER_SECURITY_PROTOCOL_MAP: CONTROLLER:PLAINTEXT,PLAINTEXT:PLAINTEXT,EXTERNAL:PLAINTEXT
      KAFKA_CFG_CONTROLLER_LISTENER_NAMES: CONTROLLER
      KAFKA_CFG_INTER_BROKER_LISTENER_NAME: PLAINTEXT
      KAFKA_CFG_AUTO_CREATE_TOPICS_ENABLE: "true"
      ALLOW_PLAINTEXT_LISTENER: "yes"
    volumes:
      - kafka_data:/bitnami/kafka
    healthcheck:
      test: ["CMD", "kafka-topics.sh", "--bootstrap-server", "localhost:9092", "--list"]
      interval: 10s
      timeout: 10s
      retries: 10

  kafka-ui:
    image: provectuslabs/kafka-ui:latest
    container_name: jmi-kafka-ui
    depends_on:
      - kafka
    ports:
      - "8085:8080"
    environment:
      KAFKA_CLUSTERS_0_NAME: local
      KAFKA_CLUSTERS_0_BOOTSTRAPSERVERS: kafka:9092

  # ---------------------------------------------------------------------
  # Spark (batch/streaming transformation + data quality layer)
  # ---------------------------------------------------------------------
  spark-master:
    image: bitnami/spark:3.5
    container_name: jmi-spark-master
    environment:
      SPARK_MODE: master
    ports:
      - "8080:8080"   # Spark master UI
      - "7077:7077"
    volumes:
      - ../:/opt/project

  spark-worker:
    image: bitnami/spark:3.5
    container_name: jmi-spark-worker
    depends_on:
      - spark-master
    environment:
      SPARK_MODE: worker
      SPARK_MASTER_URL: spark://spark-master:7077
      SPARK_WORKER_CORES: "2"
      SPARK_WORKER_MEMORY: 2G
    volumes:
      - ../:/opt/project

  # ---------------------------------------------------------------------
  # Airflow metadata DB (kept separate from the app's own Postgres in .env)
  # ---------------------------------------------------------------------
  airflow-db:
    image: postgres:16
    container_name: jmi-airflow-db
    environment:
      POSTGRES_USER: airflow
      POSTGRES_PASSWORD: airflow
      POSTGRES_DB: airflow
    volumes:
      - airflow_db_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U airflow"]
      interval: 5s
      timeout: 5s
      retries: 10

  airflow-init:
    build:
      context: ./airflow
    container_name: jmi-airflow-init
    depends_on:
      airflow-db:
        condition: service_healthy
    environment: &airflow-env
      AIRFLOW__CORE__EXECUTOR: LocalExecutor
      AIRFLOW__DATABASE__SQL_ALCHEMY_CONN: postgresql+psycopg2://airflow:airflow@airflow-db/airflow
      AIRFLOW__CORE__LOAD_EXAMPLES: "false"
      AIRFLOW__API__AUTH_BACKENDS: airflow.api.auth.backend.basic_auth
    entrypoint: /bin/bash
    command: >
      -c "airflow db migrate &&
          airflow users create --username admin --password admin
            --firstname Admin --lastname User --role Admin --email admin@example.com"
    volumes:
      - ./airflow/dags:/opt/airflow/dags
      - ../:/opt/project

  airflow-webserver:
    build:
      context: ./airflow
    container_name: jmi-airflow-webserver
    depends_on:
      - airflow-init
    environment: *airflow-env
    ports:
      - "8081:8080"
    command: webserver
    volumes:
      - ./airflow/dags:/opt/airflow/dags
      - ../:/opt/project
      - ../.env:/opt/project/.env

  airflow-scheduler:
    build:
      context: ./airflow
    container_name: jmi-airflow-scheduler
    depends_on:
      - airflow-init
    environment: *airflow-env
    command: scheduler
    volumes:
      - ./airflow/dags:/opt/airflow/dags
      - ../:/opt/project
      - ../.env:/opt/project/.env

volumes:
  kafka_data:
  airflow_db_data:
